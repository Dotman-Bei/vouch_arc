{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../.env -- next dev -p 3000",
    "build": "pnpm prisma:generate && dotenv -e ../.env -- next build",
    "start": "dotenv -e ../.env -- next start -p 3000",
    "lint": "next lint",
    "prisma:sync": "node -e \"require('fs').copyFileSync('../agent/prisma/schema.prisma','./prisma/schema.prisma')\"",
    "prisma:generate": "pnpm prisma:sync && node ../scripts/prisma-generate.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.51.0",
    "ethers": "^6.13.0",
    "gsap": "^3.15.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.12.7",
    "viem": "^2.50.4",
    "wagmi": "^2.19.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0"
  }
}
