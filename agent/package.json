{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/index.ts",
    "run-once": "dotenv -e ../.env -- tsx src/index.ts --once",
    "run-force": "dotenv -e ../.env -- tsx src/index.ts --once --force",
    "analyze-one": "dotenv -e ../.env -- tsx src/analyze-one.ts",
    "start": "dotenv -e ../.env -- node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "node ../scripts/prisma-generate.mjs",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "prisma:reset": "dotenv -e ../.env -- prisma migrate reset --force",
    "prisma:studio": "dotenv -e ../.env -- prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@prisma/client": "^5.18.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "node-cron": "^3.0.3",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "undici": "^6.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.18.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
}
