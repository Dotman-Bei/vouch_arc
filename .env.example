# ─── Shared ─────────────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Required for real deployments. Local Hardhat tests use a zero address internally.
ARC_USYC_ADDRESS=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C
ARC_USYC_TELLER_ADDRESS=0x9fdF14c5B14173D74C08Af27AebFf39240dC105A
# Arc testnet USYC teller is permissioned. Keep disabled unless the vault is allowlisted.
ARC_ENABLE_USYC_TELLER=false

# ─── Contracts deploy ───────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
AGENT_ADDRESS=

# Filled in after deploy:
LEADER_ORACLE_ADDRESS=
BOND_REGISTRY_ADDRESS=
FOLLOWER_VAULT_ADDRESS=

# ─── Agent ──────────────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY=
HL_API_URL=https://api.hyperliquid.xyz/info
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
PINATA_JWT=
DATABASE_URL=postgresql://user:pass@localhost:5432/vouch
DIRECT_URL=postgresql://user:pass@localhost:5432/vouch
DISCORD_WEBHOOK_URL=
# Poll often so newly bonded leaders are scored within minutes.
AGENT_CRON=*/5 * * * *
# Existing scored leaders are re-analyzed at this slower monitoring interval.
AGENT_MIN_ANALYSIS_INTERVAL_MINUTES=60

# Degradation thresholds (override defaults if needed)
DEGRADATION_SLASH_THRESHOLD=50
MAX_SLASH_BPS=8000

# ─── Seed a demo leader (pnpm contracts:seed) ───────────────────────────────
# The DEPLOYER_PRIVATE_KEY signer posts the bond and becomes the on-chain leader.
SEED_HL_WALLET=
SEED_HANDLE=Demo Leader
SEED_BOND_USDC=100

# ─── Web ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_LEADER_ORACLE_ADDRESS=
NEXT_PUBLIC_BOND_REGISTRY_ADDRESS=
NEXT_PUBLIC_FOLLOWER_VAULT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_USYC_ADDRESS=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C

# Wallet connection (RainbowKit/Reown). Required by RainbowKit config.
# Free at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
